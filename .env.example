# ============================================================
# Copy file ini ke .env dan isi nilai yang sebenarnya.
# JANGAN commit .env — hanya .env.example yang boleh di-commit.
# ============================================================

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Exa (web search) — https://dashboard.exa.ai
EXA_API_KEY=your-exa-key-here

# Voyage (embeddings) — https://dash.voyageai.com
# Optional untuk MVP — bisa dikosongkan dulu
VOYAGE_API_KEY=your-voyage-key-here

# Database
POSTGRES_USER=researchpilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=researchpilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://researchpilot:changeme@postgres:5432/researchpilot

# Redis
REDIS_URL=redis://redis:6379/0

# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-random-32-char-string

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth (Clerk) — https://dashboard.clerk.com
# Skip untuk local development (APP_ENV=development bypass auth otomatis)
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
